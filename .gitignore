.apptainer-build-cache/

# Container runner temp (TMPDIR under bind mount; apptainer/run_tests_and_examples.sh)
.container_tmp/

# Apptainer overlay disk images (runtime; keep apptainer/overlays/ in repo via .gitkeep)
apptainer/overlays/*.img


