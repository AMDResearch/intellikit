#!/usr/bin/env python3
"""Editable Triton reproducer — generated by kerncap (HSA backend).

Kernel:    {{ kernel_name }}
Grid:      ({{ grid.x }}, {{ grid.y }}, {{ grid.z }})
Block:     ({{ block.x }}, {{ block.y }}, {{ block.z }})
{% if launch -%}
Launch:    {{ launch }}
{%- endif %}

Edit `{{ kernel_module }}.py` and rerun this script to recompile and
re-run the kernel.  Triton's JIT will detect the source change, rebuild
the HSACO automatically, and dispatch the new kernel.  Outputs are
written to `reference_output/` so you can diff against the byte-faithful
capture-time outputs in the same directory.

Generated artifacts:
  - `{{ kernel_module }}.py`            : standalone Triton kernel source
  - `capture/`                          : byte-faithful HSA artifacts
  - `capture/kernel.hsaco`              : original HSACO (pre-edit)
  - `capture/kernarg_raw.bin`           : exact kernarg buffer the GPU saw
  - `capture/memory/region_*.bin`       : exact pointer-backed buffers
  - `capture/name_map.json`             : signature, constexprs, layout
  - `reference_output/`                 : outputs from THIS run
"""

import os
import struct
import sys
import time

import numpy as np
import torch
import triton
import triton.language as tl

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
CAPTURE_DIR = os.path.join(SCRIPT_DIR, "capture")
MEMORY_DIR = os.path.join(CAPTURE_DIR, "memory")
REFOUT_DIR = os.path.join(SCRIPT_DIR, "reference_output")
CANDIDATE_HSACO = os.path.join(SCRIPT_DIR, "candidate.hsaco")

sys.path.insert(0, SCRIPT_DIR)
{% if deps_dir -%}
sys.path.insert(0, os.path.join(SCRIPT_DIR, "{{ deps_dir }}"))
{%- endif %}

from {{ kernel_module }} import {{ kernel_function }}  # noqa: E402

# Bypass any wrapping autotuner/heuristics so we run the captured config
# verbatim.  The user's edits to the kernel body still take effect.
_kernel = {{ kernel_function }}
for _attr in ("fn", "base_fn"):
    _inner = getattr(_kernel, _attr, None)
    if _inner is not None and hasattr(_inner, "params"):
        _kernel = _inner


# Triton pointer-dtype string -> (numpy load dtype, torch dtype, itemsize, special)
TRITON_POINTER_DTYPE_MAP = {
    "*fp16":   (np.float16, torch.float16, 2, None),
    "*fp32":   (np.float32, torch.float32, 4, None),
    "*fp64":   (np.float64, torch.float64, 8, None),
    "*bf16":   (np.uint16,  torch.bfloat16, 2, "bf16"),
    "*i8":     (np.int8,    torch.int8, 1, None),
    "*i16":    (np.int16,   torch.int16, 2, None),
    "*i32":    (np.int32,   torch.int32, 4, None),
    "*i64":    (np.int64,   torch.int64, 8, None),
    "*u8":     (np.uint8,   torch.uint8, 1, None),
    "*u16":    (np.uint16,  None, 2, None),
    "*u32":    (np.uint32,  None, 4, None),
    "*u64":    (np.uint64,  None, 8, None),
    "*i1":     (np.bool_,   torch.bool, 1, None),
    "*bool":   (np.bool_,   torch.bool, 1, None),
}


def _torch_dtype_for(triton_dtype):
    info = TRITON_POINTER_DTYPE_MAP.get(triton_dtype)
    if info is None:
        raise NotImplementedError(
            f"Unmapped Triton pointer dtype: {triton_dtype!r}.  "
            f"Add it to TRITON_POINTER_DTYPE_MAP above."
        )
    return info


def _load_pointer(region_file, byte_offset, triton_dtype, shape, stride, storage_offset):
    """Load a pointer-backed buffer from a captured memory region.

    The HSA layer captured the *full byte-exact* contents of the VA
    region containing this pointer.  *byte_offset* is the offset within
    that region where the kernarg pointer was located (i.e. the view
    base, since Triton passes ``tensor.data_ptr()``).  *shape*/*stride*
    come from the runtime observer; *storage_offset* is the original
    PyTorch tensor's ``storage_offset()`` in *elements*.

    The kernarg pointer satisfies::

        kernarg_ptr = storage_base + storage_offset * itemsize

    so the storage base sits ``storage_offset * itemsize`` bytes before
    the kernarg pointer, i.e. at byte
    ``storage_byte_off = byte_offset - storage_offset * itemsize``
    within the region.  When that's ``>= 0`` (the common case: the HSA
    layer captured the full backing allocation, so ``region_base ==
    storage_base`` and ``storage_byte_off == 0``), we slice the raw
    bytes from the storage base and let ``as_strided`` apply the
    recorded ``storage_offset`` -- this preserves the original strided
    layout, including views into a larger slab.

    When ``storage_byte_off < 0`` (very unusual; would mean torch's
    storage straddles outside the tracked allocation) we fall back to
    slicing from the kernarg pointer and treating the view base as the
    new storage origin (``storage_offset=0``).  Best-effort: only
    correct for views whose strided extent fits in the bytes after
    ``byte_offset``.
    """
    np_dtype, torch_dtype, itemsize, special = _torch_dtype_for(triton_dtype)
    if torch_dtype is None:
        raise NotImplementedError(
            f"No torch dtype available for Triton type {triton_dtype!r}"
        )
    raw = np.fromfile(region_file, dtype=np.uint8)

    storage_byte_off = byte_offset - storage_offset * itemsize
    if storage_offset and storage_byte_off >= 0:
        raw = raw[storage_byte_off:]
        effective_storage_offset = storage_offset
    else:
        raw = raw[byte_offset:]
        effective_storage_offset = 0

    usable = (len(raw) // itemsize) * itemsize
    raw = raw[:usable]
    if special == "bf16":
        data = raw.view(np.uint16)
        tensor = torch.from_numpy(data.copy()).view(torch.bfloat16)
    else:
        data = raw.view(np_dtype)
        tensor = torch.from_numpy(data.copy())
    tensor = tensor.to(device="cuda")
    if torch_dtype is not None and tensor.dtype != torch_dtype:
        tensor = tensor.view(torch_dtype) if special == "bf16" else tensor.to(torch_dtype)

    if shape is not None:
        if stride is not None:
            tensor = torch.as_strided(tensor, shape, stride, effective_storage_offset)
        else:
            try:
                tensor = tensor.reshape(shape)
            except RuntimeError:
                pass
    return tensor


# ---------------------------------------------------------------------------
# Capture the just-JITted HSACO via a ``triton.compiler.compile`` wrapper.
#
# We install the wrapper at module load -- *before* anything imports our
# Triton kernel -- and let it record every ``CompiledKernel`` Triton
# produces for the lifetime of this process.  After ``_launch()``, the
# most recently captured HSACO is written next to this file as
# ``candidate.hsaco`` so ``kerncap validate`` (and
# ``kerncap-replay --hsaco ...``) can byte-diff it against the captured
# baseline without the user fishing through ``$TRITON_HOME/.triton/cache``.
#
# This mirrors the same compile-hook pattern ``kerncap``'s capture path
# uses (see ``triton_capture_hsa.py``): we observe at the boundary of
# the action we care about (compile completion) rather than scanning
# Triton's on-disk cache for files we hope are the right ones.  It is
# also robust to cache hits -- ``triton.compiler.compile`` is invoked on
# every launch and returns the cached ``CompiledKernel``, so the wrapper
# always sees the canonical artifact for *this* run regardless of
# whether a JIT compile actually fired.
# ---------------------------------------------------------------------------
_CAPTURED_COMPILED_KERNELS = []


def _install_compile_hook():
    """Wrap ``triton.compiler.compile`` to capture every ``CompiledKernel``.

    Idempotent: re-importing this module (or re-running it) won't stack
    multiple wrappers.  Falls through silently on any failure -- the
    user still gets a working reproducer, just without the convenience
    of an auto-saved ``candidate.hsaco``.
    """
    try:
        import triton.compiler as _tc
    except Exception:
        return
    if getattr(getattr(_tc, "compile", None), "_kerncap_compile_hook", False):
        return
    if not hasattr(_tc, "compile"):
        return
    _orig = _tc.compile

    def _wrapped(*args, **kwargs):
        ck = _orig(*args, **kwargs)
        try:
            _CAPTURED_COMPILED_KERNELS.append(ck)
        except Exception:
            pass
        return ck

    _wrapped._kerncap_compile_hook = True
    _tc.compile = _wrapped


_install_compile_hook()


def _save_candidate_hsaco(dst_path):
    """Write the most-recently-captured HSACO to *dst_path*, if any.

    Returns the path on success, ``None`` if no compile was observed
    or the ``CompiledKernel`` doesn't expose its HSACO via the
    ``asm["hsaco"]`` accessor.
    """
    if not _CAPTURED_COMPILED_KERNELS:
        return None
    ck = _CAPTURED_COMPILED_KERNELS[-1]
    try:
        blob = ck.asm["hsaco"]
    except (AttributeError, KeyError, TypeError):
        return None
    if not isinstance(blob, (bytes, bytearray)):
        return None
    with open(dst_path, "wb") as f:
        f.write(bytes(blob))
    return dst_path


def main():
    os.makedirs(REFOUT_DIR, exist_ok=True)

    # ---- Pointer args (from capture/memory/region_*.bin) ----
{% for arg in pointer_args %}
    # {{ arg.name }} : {{ arg.triton_dtype }}{% if arg.shape %} shape={{ arg.shape }} stride={{ arg.stride }}{% endif %}
    {{ arg.name }} = _load_pointer(
        os.path.join(MEMORY_DIR, "{{ arg.region_file }}"),
        byte_offset={{ arg.byte_offset }},
        triton_dtype="{{ arg.triton_dtype }}",
        shape={{ arg.shape | pyrepr if arg.shape is not none else 'None' }},
        stride={{ arg.stride | pyrepr if arg.stride is not none else 'None' }},
        storage_offset={{ arg.storage_offset }},
    )
{% endfor %}

    # ---- Scalar args (decoded from capture/kernarg_raw.bin) ----
{% for arg in scalar_args %}
    {{ arg.name }} = {{ arg.value | pyrepr }}  # {{ arg.value_type }} @ kernarg offset {{ arg.offset }}
{% endfor %}

    # Closure so the kernarg locals above are in scope for both the
    # warmup and timed launches.  Defined inside main() on purpose --
    # making this module-level would break the reference resolution.
    def _launch():
        return _kernel[({{ grid.x }}, {{ grid.y }}, {{ grid.z }})](
{%- for arg in pointer_args %}
            {{ arg.name }}={{ arg.name }},
{%- endfor %}
{%- for arg in scalar_args %}
            {{ arg.name }}={{ arg.name }},
{%- endfor %}
{%- for k, v in constexprs.items() %}
            {{ k }}={{ v | constrepr }},
{%- endfor %}
{%- if launch.num_warps is defined %}
            num_warps={{ launch.num_warps }},
{%- endif %}
{%- if launch.num_stages is defined %}
            num_stages={{ launch.num_stages }},
{%- endif %}
        )

    # ---- Warmup (Triton JIT will recompile if {{ kernel_module }}.py was edited) ----
    _launch()
    torch.cuda.synchronize()

    # Snapshot the just-compiled HSACO so `kerncap validate` and
    # `kerncap-replay --hsaco ...` can diff this run against the
    # captured baseline without the user fishing through Triton's cache.
    saved = _save_candidate_hsaco(CANDIDATE_HSACO)
    if saved:
        print(f"Wrote candidate HSACO -> {saved}")
    else:
        print(
            "WARNING: could not auto-save candidate HSACO "
            "(triton.compiler.compile wrapper did not see a CompiledKernel "
            "with asm['hsaco']).  `kerncap validate` will fall back to "
            "smoke mode; pass `--hsaco PATH` explicitly to byte-diff a "
            "specific HSACO against the captured baseline.",
            file=sys.stderr,
        )

    # ---- Timed run ----
    start = time.perf_counter()
    _launch()
    torch.cuda.synchronize()
    elapsed_ms = (time.perf_counter() - start) * 1000
    print(f"Kernel execution time: {elapsed_ms:.3f} ms")

    # ---- Save outputs (one file per pointer arg) ----
{% for arg in pointer_args %}
    out_path_{{ loop.index0 }} = os.path.join(
        REFOUT_DIR, "output_{{ arg.index }}_{{ arg.name }}.bin"
    )
    out_{{ loop.index0 }} = {{ arg.name }}.detach().cpu().contiguous()
    if out_{{ loop.index0 }}.dtype == torch.bfloat16:
        out_{{ loop.index0 }}.view(torch.uint16).numpy().tofile(out_path_{{ loop.index0 }})
    else:
        out_{{ loop.index0 }}.numpy().tofile(out_path_{{ loop.index0 }})
    print(
        f"Saved {out_{{ loop.index0 }}.numel() * out_{{ loop.index0 }}.element_size()} "
        f"bytes -> {out_path_{{ loop.index0 }}}"
    )
{% endfor %}

    print("Reproducer completed successfully.")


if __name__ == "__main__":
    main()
